APP_NAME=Renpresso
APP_ENV=production
APP_KEY=                        # php artisan key:generate --show
APP_DEBUG=false
APP_TIMEZONE=UTC
APP_URL=https://renpresso.com
# Hosts that may serve the app (comma-separated). Links/forms use the host you are on.
# Emails and console still use APP_URL as the canonical domain.
APP_ALLOWED_HOSTS=renpresso.com,www.renpresso.com,renpresso-production.up.railway.app
# Optional shorthand if you skip APP_ALLOWED_HOSTS:
# APP_RAILWAY_URL=https://renpresso-production.up.railway.app

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ── Database (PostgreSQL) ──────────────────────────────────────────────────────
# Railway Option A: reference DATABASE_PRIVATE_URL from Postgres on the web service.
# Railway Option B: reference PGHOST→DB_HOST, PGPORT→DB_PORT, PGUSER→DB_USERNAME,
#   PGPASSWORD→DB_PASSWORD, PGDATABASE→DB_DATABASE (see README Deploy section).
DB_CONNECTION=pgsql
# DB_URL=
# DATABASE_URL=
# DATABASE_PRIVATE_URL=
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=renpresso
DB_USERNAME=postgres
DB_PASSWORD=postgres

# ── Cache / Session / Queue ────────────────────────────────────────────────────
# Default: file/sync (works without Redis). entrypoint.sh also forces these when REDIS_URL is unset.
CACHE_STORE=file
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
# With Railway Redis plugin — reference REDIS_URL, then switch to:
# CACHE_STORE=redis
# QUEUE_CONNECTION=redis
# SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null

# ── Redis / Valkey ─────────────────────────────────────────────────────────────
# Railway: add Redis plugin → reference REDIS_URL on the web service.
REDIS_CLIENT=phpredis
REDIS_URL=
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ── Mail ───────────────────────────────────────────────────────────────────────
# Recommended: Postmark or Resend for transactional email (Laravel Cloud compatible).
MAIL_MAILER=smtp
MAIL_HOST=smtp.postmarkapp.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=hello@renpresso.com
MAIL_FROM_NAME="Renpresso"

# ── Payment processors (secrets in .env only — Admin → Payments → Processors refreshes Keys set / No keys on each visit)
# stripe, stripe_billing
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=
# razorpay, razorpay_billing
RAZORPAY_KEY=
RAZORPAY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
# flutterwave
FLUTTERWAVE_PUBLIC_KEY=
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_ENCRYPTION_KEY=
FLUTTERWAVE_WEBHOOK_SECRET=
# xendit
XENDIT_SECRET_KEY=
XENDIT_WEBHOOK_TOKEN=
# mercadopago
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_WEBHOOK_SECRET=
# square (US/CA card collection — card-first, lowest fee 2.6%)
SQUARE_APPLICATION_ID=
SQUARE_ACCESS_TOKEN=
SQUARE_LOCATION_ID=
SQUARE_WEBHOOK_SIGNATURE_KEY=
SQUARE_ENVIRONMENT=sandbox
# paddle
PADDLE_API_KEY=
PADDLE_WEBHOOK_SECRET=
# chargebee
CHARGEBEE_API_KEY=
CHARGEBEE_SITE=
# braintree
BRAINTREE_MERCHANT_ID=
BRAINTREE_PUBLIC_KEY=
BRAINTREE_PRIVATE_KEY=
# paypal (wallet + global card collection — 200+ countries)
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=
PAYPAL_MODE=sandbox
# recurly
RECURLY_API_KEY=
RECURLY_SUBDOMAIN=
# adyen
ADYEN_API_KEY=
ADYEN_MERCHANT_ACCOUNT=
ADYEN_HMAC_KEY=
# coinbase
COINBASE_COMMERCE_API_KEY=

# ── Storage ────────────────────────────────────────────────────────────────────
# Laravel Cloud: Add an "Object Storage" (S3-compatible) resource — credentials auto-injected.
# Or use Cloudflare R2 (set AWS_USE_PATH_STYLE_ENDPOINT=true and R2_S3_API_ENDPOINT).
FILESYSTEM_DISK=s3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=renpresso-documents
AWS_USE_PATH_STYLE_ENDPOINT=false
# R2_S3_API_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com

# wise (outbound landlord payouts — NOT for collecting rent)
WISE_API_KEY=
WISE_PROFILE_ID=
WISE_ENVIRONMENT=sandbox

# ── FX / Currency ─────────────────────────────────────────────────────────────
FX_API_KEY=
FX_API_URL=https://v6.exchangerate-api.com/v6

# ── Logging ────────────────────────────────────────────────────────────────────
# Laravel Cloud streams logs automatically; keep stack/single for local dev.
LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=error                 # use "debug" locally only

# ── Vite ───────────────────────────────────────────────────────────────────────
VITE_APP_NAME="${APP_NAME}"
